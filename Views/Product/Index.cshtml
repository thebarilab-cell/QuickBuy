@model List<QuickBuy.Web.Models.ProductVM>
@{
    ViewData["Title"] = "All Products";
}

<div class="container">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                    <li class="breadcrumb-item active">Products</li>
                </ol>
            </nav>

            <div class="d-flex justify-content-between align-items-center">
                <h1>All Products</h1>
                @if (ViewBag.CategoryId != null)
                {
                    <span class="badge bg-primary fs-6">Category Filter Applied</span>
                }
                @if (!string.IsNullOrEmpty(ViewBag.SearchTerm))
                {
                    <span class="badge bg-info fs-6">Search: @ViewBag.SearchTerm</span>
                }
            </div>
            <p class="text-muted">Showing @Model.Count products</p>
        </div>
    </div>

    <!-- Filter and Sort Section -->
    <div class="row mb-4">
        <div class="col-md-8">
            <div class="btn-group" role="group">
                <a asp-action="Index" class="btn @(ViewBag.CategoryId == null ? "btn-primary" : "btn-outline-primary")">
                    All Products
                </a>
                <a asp-action="Category" asp-route-id="1" class="btn @(ViewBag.CategoryId == 1 ? "btn-primary" : "btn-outline-primary")">
                    Electronics
                </a>
                <a asp-action="Category" asp-route-id="2" class="btn @(ViewBag.CategoryId == 2 ? "btn-primary" : "btn-outline-primary")">
                    Fashion
                </a>
                <a asp-action="Category" asp-route-id="3" class="btn @(ViewBag.CategoryId == 3 ? "btn-primary" : "btn-outline-primary")">
                    Home & Kitchen
                </a>
                <a asp-action="Category" asp-route-id="4" class="btn @(ViewBag.CategoryId == 4 ? "btn-primary" : "btn-outline-primary")">
                    Books
                </a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="input-group">
                <span class="input-group-text"><i class="fas fa-sort"></i></span>
                <select class="form-select" id="sortSelect">
                    <option value="newest">Newest First</option>
                    <option value="price_low">Price: Low to High</option>
                    <option value="price_high">Price: High to Low</option>
                    <option value="discount">Best Discount</option>
                    <option value="name">Name A-Z</option>
                </select>
            </div>
        </div>
    </div>

    <!-- Products Grid -->
    @if (Model.Any())
    {
        <div class="row g-4" id="productsContainer">
            @foreach (var product in Model)
            {
                <div class="col-xl-3 col-lg-4 col-md-6">
                    <div class="card product-card h-100">
                        @if (product.DiscountPercentage > 0)
                        {
                            <div class="badge bg-danger position-absolute" style="top: 10px; right: 10px;">
                                SAVE @product.DiscountPercentage%
                            </div>
                        }
                        <div class="product-image-wrapper">
                            <img src="@product.ImageUrl" class="card-img-top" alt="@product.Name"
                                 style="height: 250px; object-fit: cover; cursor: pointer;"
                                 onclick="location.href='@Url.Action("Details", new { id = product.Id })'">
                        </div>
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title mb-0" style="cursor: pointer;"
                                    onclick="location.href='@Url.Action("Details", new { id = product.Id })'">
                                    @product.Name
                                </h5>
                                <span class="badge bg-info">@product.CategoryName</span>
                            </div>
                            <p class="card-text text-muted small mb-3">
                                @(product.Description.Length > 80 ? product.Description.Substring(0, 80) + "..." : product.Description)
                            </p>

                            <div class="price-section mb-3">
                                @if (product.DiscountPrice > 0)
                                {
                                    <div class="d-flex align-items-center">
                                        <span class="text-danger fs-4 fw-bold">$@product.DiscountPrice.ToString("N2")</span>
                                        <span class="text-muted text-decoration-line-through ms-2">$@product.Price.ToString("N2")</span>
                                        <span class="badge bg-success ms-2">Save $@product.Savings.ToString("N2")</span>
                                    </div>
                                }
                                else
                                {
                                    <span class="fs-4 fw-bold">$@product.Price.ToString("N2")</span>
                                }
                            </div>

                            <div class="stock-info mb-3">
                                @if (product.StockQuantity > 10)
                                {
                                    <span class="text-success"><i class="fas fa-check-circle"></i> In Stock</span>
                                }
                                else if (product.StockQuantity > 0)
                                {
                                    <span class="text-warning"><i class="fas fa-exclamation-circle"></i> Only @product.StockQuantity left</span>
                                }
                                else
                                {
                                    <span class="text-danger"><i class="fas fa-times-circle"></i> Out of Stock</span>
                                }
                            </div>

                            <div class="d-grid gap-2">
                                <a asp-action="Details" asp-route-id="@product.Id" class="btn btn-outline-primary">
                                    <i class="fas fa-eye"></i> View Details
                                </a>
                                @if (product.StockQuantity > 0)
                                {
                                    <form asp-controller="Cart" asp-action="AddToCart" method="post">
                                        <input type="hidden" name="productId" value="@product.Id" />
                                        <input type="hidden" name="quantity" value="1" />
                                        <button type="submit" class="btn btn-primary w-100" @(product.StockQuantity == 0 ? "disabled" : "")>
                                            <i class="fas fa-cart-plus"></i> Add to Cart
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <button class="btn btn-secondary w-100" disabled>
                                        <i class="fas fa-bell"></i> Notify Me
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="fas fa-search fa-4x text-muted mb-4"></i>
            <h3>No Products Found</h3>
            <p class="text-muted">Try adjusting your search or filter to find what you're looking for.</p>
            <a asp-action="Index" class="btn btn-primary">View All Products</a>
        </div>
    }

    <!-- Pagination (would be implemented with actual pagination) -->
    @if (Model.Count >= 12)
    {
        <nav aria-label="Page navigation" class="mt-5">
            <ul class="pagination justify-content-center">
                <li class="page-item disabled">
                    <a class="page-link" href="#" tabindex="-1">Previous</a>
                </li>
                <li class="page-item active"><a class="page-link" href="#">1</a></li>
                <li class="page-item"><a class="page-link" href="#">2</a></li>
                <li class="page-item"><a class="page-link" href="#">3</a></li>
                <li class="page-item">
                    <a class="page-link" href="#">Next</a>
                </li>
            </ul>
        </nav>
    }
</div>

@section Scripts {
    <script>
        // Sort functionality
        $('#sortSelect').change(function() {
            sortProducts($(this).val());
        });

        function sortProducts(sortBy) {
            var products = $('#productsContainer .col-xl-3');
            var sorted = products.sort(function(a, b) {
                var aPrice = parseFloat($(a).find('.price-section .fw-bold').text().replace('$', ''));
                var bPrice = parseFloat($(b).find('.price-section .fw-bold').text().replace('$', ''));
                var aName = $(a).find('.card-title').text();
                var bName = $(b).find('.card-title').text();
                var aDiscount = $(a).find('.badge.bg-danger').length > 0;
                var bDiscount = $(b).find('.badge.bg-danger').length > 0;

                switch(sortBy) {
                    case 'price_low':
                        return aPrice - bPrice;
                    case 'price_high':
                        return bPrice - aPrice;
                    case 'name':
                        return aName.localeCompare(bName);
                    case 'discount':
                        return (bDiscount ? 1 : 0) - (aDiscount ? 1 : 0);
                    default: // newest
                        return 0;
                }
            });

            $('#productsContainer').html(sorted);
        }
    </script>
}
