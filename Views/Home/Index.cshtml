@{
    ViewData["Title"] = "Welcome to QuickBuy";
}

<!-- Hero Section -->
<section class="hero-section mb-5">
    <div class="container-fluid p-0">
        <div class="hero-slider">
            <div id="heroCarousel" class="carousel slide" data-bs-ride="carousel">
                <div class="carousel-indicators">
                    <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active"></button>
                    <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1"></button>
                    <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2"></button>
                </div>
                <div class="carousel-inner">
                    <div class="carousel-item active">
                        <img src="/images/hero1.jpg" class="d-block w-100" alt="Hero Image 1" style="height: 500px; object-fit: cover;">
                        <div class="carousel-caption d-none d-md-block">
                            <h2 class="display-4">Summer Sale Up to 50% Off</h2>
                            <p class="lead">Discover amazing products at unbelievable prices</p>
                            <a asp-controller="Product" asp-action="Index" class="btn btn-primary btn-lg">Shop Now</a>
                        </div>
                    </div>
                    <div class="carousel-item">
                        <img src="/images/hero2.jpg" class="d-block w-100" alt="Hero Image 2" style="height: 500px; object-fit: cover;">
                        <div class="carousel-caption d-none d-md-block">
                            <h2 class="display-4">New Arrivals</h2>
                            <p class="lead">Check out our latest collection</p>
                            <a asp-controller="Product" asp-action="Index" class="btn btn-primary btn-lg">Explore</a>
                        </div>
                    </div>
                    <div class="carousel-item">
                        <img src="/images/hero3.jpg" class="d-block w-100" alt="Hero Image 3" style="height: 500px; object-fit: cover;">
                        <div class="carousel-caption d-none d-md-block">
                            <h2 class="display-4">Free Shipping</h2>
                            <p class="lead">On orders over $50</p>
                            <a asp-controller="Product" asp-action="Index" class="btn btn-primary btn-lg">Start Shopping</a>
                        </div>
                    </div>
                </div>
                <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon"></span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon"></span>
                </button>
            </div>
        </div>
    </div>
</section>

<!-- Featured Categories -->
<section class="categories-section mb-5">
    <div class="container">
        <h2 class="section-title text-center mb-4">Shop by Category</h2>
        <div class="row g-4">
            <div class="col-md-3 col-sm-6">
                <div class="category-card text-center">
                    <a asp-controller="Product" asp-action="Category" asp-route-id="1" class="text-decoration-none">
                        <div class="category-icon mb-3">
                            <i class="fas fa-laptop fa-3x text-primary"></i>
                        </div>
                        <h4>Electronics</h4>
                        <p class="text-muted">Latest gadgets & devices</p>
                    </a>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="category-card text-center">
                    <a asp-controller="Product" asp-action="Category" asp-route-id="2" class="text-decoration-none">
                        <div class="category-icon mb-3">
                            <i class="fas fa-tshirt fa-3x text-primary"></i>
                        </div>
                        <h4>Fashion</h4>
                        <p class="text-muted">Trendy clothes & accessories</p>
                    </a>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="category-card text-center">
                    <a asp-controller="Product" asp-action="Category" asp-route-id="3" class="text-decoration-none">
                        <div class="category-icon mb-3">
                            <i class="fas fa-home fa-3x text-primary"></i>
                        </div>
                        <h4>Home & Kitchen</h4>
                        <p class="text-muted">Everything for your home</p>
                    </a>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="category-card text-center">
                    <a asp-controller="Product" asp-action="Category" asp-route-id="4" class="text-decoration-none">
                        <div class="category-icon mb-3">
                            <i class="fas fa-book fa-3x text-primary"></i>
                        </div>
                        <h4>Books</h4>
                        <p class="text-muted">Best sellers & more</p>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Featured Products -->
<section class="featured-products mb-5">
    <div class="container">
        <h2 class="section-title text-center mb-4">Featured Products</h2>
        <div class="row g-4">
            @if (ViewBag.FeaturedProducts != null)
            {
                @foreach (var product in ViewBag.FeaturedProducts)
                {
                    <div class="col-lg-3 col-md-4 col-sm-6">
                        <div class="card product-card h-100">
                            @if (product.DiscountPrice > 0)
                            {
                                <div class="badge bg-danger position-absolute" style="top: 10px; right: 10px;">
                                    SAVE @((int)((product.Price - product.DiscountPrice) / product.Price * 100))%
                                </div>
                            }
                            <img src="@product.ImageUrl" class="card-img-top" alt="@product.Name" style="height: 200px; object-fit: cover;">
                            <div class="card-body">
                                <h5 class="card-title">@product.Name</h5>
                                <p class="card-text text-muted">@(product.Description.Length > 50 ? product.Description.Substring(0, 50) + "..." : product.Description)</p>
                                <div class="price mb-3">
                                    @if (product.DiscountPrice > 0)
                                    {
                                        <span class="text-danger fs-4 fw-bold">$@product.DiscountPrice.ToString("N2")</span>
                                        <span class="text-muted text-decoration-line-through ms-2">$@product.Price.ToString("N2")</span>
                                    }

                                    else
                                    {
                                        <span class="fs-4 fw-bold">$@product.Price.ToString("N2")</span>
                                    }
                                </div>
                                <div class="d-grid gap-2">
                                    <a asp-controller="Product" asp-action="Details" asp-route-id="@product.Id" class="btn btn-outline-primary">
                                        <i class="fas fa-eye"></i> View Details
                                    </a>
                                    <form asp-controller="Cart" asp-action="AddToCart" method="post">
                                        <input type="hidden" name="productId" value="@product.Id" />
                                        <input type="hidden" name="quantity" value="1" />
                                        <button type="submit" class="btn btn-primary w-100">
                                            <i class="fas fa-cart-plus"></i> Add to Cart
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
        <div class="text-center mt-4">
            <a asp-controller="Product" asp-action="Index" class="btn btn-outline-primary btn-lg">
                View All Products <i class="fas fa-arrow-right"></i>
            </a>
        </div>
    </div>
</section>

<!-- Why Choose Us -->
<section class="why-choose-us mb-5 bg-light py-5">
    <div class="container">
        <h2 class="section-title text-center mb-4">Why Choose QuickBuy?</h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="text-center p-4">
                    <div class="feature-icon mb-3">
                        <i class="fas fa-shipping-fast fa-3x text-primary"></i>
                    </div>
                    <h4>Free Shipping</h4>
                    <p class="text-muted">Free shipping on all orders over $50</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="text-center p-4">
                    <div class="feature-icon mb-3">
                        <i class="fas fa-undo-alt fa-3x text-primary"></i>
                    </div>
                    <h4>30-Day Returns</h4>
                    <p class="text-muted">Easy returns within 30 days of purchase</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="text-center p-4">
                    <div class="feature-icon mb-3">
                        <i class="fas fa-headset fa-3x text-primary"></i>
                    </div>
                    <h4>24/7 Support</h4>
                    <p class="text-muted">Round-the-clock customer support</p>
                </div>
            </div>
        </div>
    </div>
</section>
