@{
    ViewData["Title"] = "About Us";
}

<div class="container">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <!-- Hero Section -->
            <div class="text-center mb-5">
                <h1 class="display-4 mb-3">About QuickBuy</h1>
                <p class="lead text-muted">Your trusted online shopping destination since 2024</p>
            </div>

            <!-- Our Story -->
            <div class="card shadow-sm mb-5">
                <div class="card-body p-5">
                    <h2 class="mb-4">Our Story</h2>
                    <p class="mb-4">
                        QuickBuy was founded in 2024 with a simple mission: to make online shopping
                        fast, easy, and accessible for everyone. What started as a small startup
                        has grown into a leading e-commerce platform serving thousands of customers
                        worldwide.
                    </p>
                    <p class="mb-4">
                        Our journey began with a vision to create a seamless shopping experience
                        that combines quality products, competitive prices, and exceptional customer
                        service. Today, we're proud to offer a curated selection of products across
                        multiple categories, all from the comfort of your home.
                    </p>
                </div>
            </div>

            <!-- Mission & Vision -->
            <div class="row g-4 mb-5">
                <div class="col-md-6">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body p-4">
                            <div class="text-center mb-4">
                                <i class="fas fa-bullseye fa-3x text-primary"></i>
                            </div>
                            <h3 class="card-title text-center mb-3">Our Mission</h3>
                            <p class="card-text text-center">
                                To provide customers with a convenient, reliable, and enjoyable
                                online shopping experience while offering the best products at
                                competitive prices.
                            </p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body p-4">
                            <div class="text-center mb-4">
                                <i class="fas fa-eye fa-3x text-primary"></i>
                            </div>
                            <h3 class="card-title text-center mb-3">Our Vision</h3>
                            <p class="card-text text-center">
                                To become the most trusted and preferred online shopping
                                destination globally, known for innovation, quality, and
                                customer satisfaction.
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Our Values -->
            <div class="card shadow-sm mb-5">
                <div class="card-body p-5">
                    <h2 class="mb-4">Our Values</h2>
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="d-flex">
                                <div class="flex-shrink-0">
                                    <i class="fas fa-heart text-primary fa-2x me-3"></i>
                                </div>
                                <div>
                                    <h5>Customer First</h5>
                                    <p class="text-muted">Our customers are at the heart of everything we do.</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="d-flex">
                                <div class="flex-shrink-0">
                                    <i class="fas fa-star text-primary fa-2x me-3"></i>
                                </div>
                                <div>
                                    <h5>Quality Assurance</h5>
                                    <p class="text-muted">We ensure every product meets our high standards.</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="d-flex">
                                <div class="flex-shrink-0">
                                    <i class="fas fa-shield-alt text-primary fa-2x me-3"></i>
                                </div>
                                <div>
                                    <h5>Trust & Transparency</h5>
                                    <p class="text-muted">We believe in honest communication and fair practices.</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="d-flex">
                                <div class="flex-shrink-0">
                                    <i class="fas fa-rocket text-primary fa-2x me-3"></i>
                                </div>
                                <div>
                                    <h5>Innovation</h5>
                                    <p class="text-muted">We continuously improve our platform and services.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Team Section -->
            <div class="card shadow-sm">
                <div class="card-body p-5">
                    <h2 class="mb-4">Meet Our Team</h2>
                    <p class="mb-5 text-muted">
                        We're a diverse team of passionate individuals dedicated to making
                        your shopping experience exceptional.
                    </p>

                    <div class="row g-4">
                        <div class="col-md-4">
                            <div class="team-member text-center">
                                <img src="https://via.placeholder.com/150" class="rounded-circle mb-3" alt="Team Member" width="120">
                                <h5>John Smith</h5>
                                <p class="text-muted">CEO & Founder</p>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="team-member text-center">
                                <img src="https://via.placeholder.com/150" class="rounded-circle mb-3" alt="Team Member" width="120">
                                <h5>Sarah Johnson</h5>
                                <p class="text-muted">Head of Operations</p>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="team-member text-center">
                                <img src="https://via.placeholder.com/150" class="rounded-circle mb-3" alt="Team Member" width="120">
                                <h5>Michael Chen</h5>
                                <p class="text-muted">Technology Director</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
