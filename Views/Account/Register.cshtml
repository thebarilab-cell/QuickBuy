@model QuickBuy.Web.Models.UserVM
@{
    ViewData["Title"] = "Register";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Register - QuickBuy</title>
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body {
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            padding: 20px 0;
        }
        .register-card {
            background: white;
            border-radius: 20px;
            box-shadow: 0 30px 80px rgba(0,0,0,0.3);
            overflow: hidden;
            animation: slideUp 0.5s ease-out;
        }
        @@keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        .register-left {
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            color: white;
            padding: 40px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }
        .register-left:before {
            content: "";
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200%;
            height: 200%;
            background: rgba(255,255,255,0.1);
            transform: rotate(45deg);
        }
        .register-right {
            padding: 40px;
        }
        .brand-logo {
            text-align: center;
            margin-bottom: 30px;
        }
        .brand-logo i {
            font-size: 3rem;
            color: #f5576c;
            animation: bounce 2s infinite;
        }
        @@keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }
        .form-control {
            border-radius: 10px;
            padding: 14px 16px;
            border: 2px solid #e0e0e0;
            transition: all 0.3s;
        }
        .form-control:focus {
            border-color: #f5576c;
            box-shadow: 0 0 0 0.2rem rgba(245, 87, 108, 0.25);
            transform: translateY(-2px);
        }
        .btn-register {
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            border: none;
            padding: 14px;
            font-weight: 600;
            border-radius: 10px;
            transition: all 0.3s;
        }
        .btn-register:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(245, 87, 108, 0.3);
        }
        .progress-bar {
            height: 4px;
            background: #e0e0e0;
            border-radius: 2px;
            margin: 20px 0;
            position: relative;
        }
        .progress {
            height: 100%;
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            border-radius: 2px;
            transition: width 0.3s;
        }
        .password-strength {
            font-size: 12px;
            margin-top: 5px;
        }
        .strength-weak { color: #dc3545; }
        .strength-medium { color: #ffc107; }
        .strength-strong { color: #28a745; }
        .form-step {
            display: none;
            animation: fadeIn 0.5s;
        }
        @@keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }
        .form-step.active {
            display: block;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="register-card">
                    <div class="row g-0">
                        <!-- Left Side - Benefits -->
                        <div class="col-md-5 d-none d-md-block">
                            <div class="register-left">
                                <div class="text-center mb-5">
                                    <i class="fas fa-shopping-cart fa-4x mb-3"></i>
                                    <h1>Join QuickBuy!</h1>
                                    <p class="lead">Create your account in seconds</p>
                                </div>
                                
                                <div class="benefits">
                                    <div class="d-flex mb-4">
                                        <div class="flex-shrink-0">
                                            <div class="rounded-circle bg-white p-2 me-3" style="width: 50px; height: 50px;">
                                                <i class="fas fa-bolt text-danger fa-lg"></i>
                                            </div>
                                        </div>
                                        <div>
                                            <h5>Fast Checkout</h5>
                                            <p class="small mb-0">Save your details for instant purchases</p>
                                        </div>
                                    </div>
                                    
                                    <div class="d-flex mb-4">
                                        <div class="flex-shrink-0">
                                            <div class="rounded-circle bg-white p-2 me-3" style="width: 50px; height: 50px;">
                                                <i class="fas fa-gift text-danger fa-lg"></i>
                                            </div>
                                        </div>
                                        <div>
                                            <h5>Exclusive Offers</h5>
                                            <p class="small mb-0">Get member-only discounts & deals</p>
                                        </div>
                                    </div>
                                    
                                    <div class="d-flex">
                                        <div class="flex-shrink-0">
                                            <div class="rounded-circle bg-white p-2 me-3" style="width: 50px; height: 50px;">
                                                <i class="fas fa-history text-danger fa-lg"></i>
                                            </div>
                                        </div>
                                        <div>
                                            <h5>Order History</h5>
                                            <p class="small mb-0">Track all your purchases in one place</p>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="mt-5 pt-4 border-top">
                                    <p class="small mb-0">
                                        <i class="fas fa-lock me-2"></i>
                                        Your information is secure with us
                                    </p>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Right Side - Registration Form -->
                        <div class="col-md-7">
                            <div class="register-right">
                                <!-- Brand Logo -->
                                <div class="brand-logo">
                                    <i class="fas fa-shopping-cart"></i>
                                    <h2 class="mb-0">Create Account</h2>
                                    <p class="text-muted">Fill in your details to get started</p>
                                </div>

                                <!-- Progress Bar -->
                                <div class="progress-bar">
                                    <div class="progress" id="registrationProgress" style="width: 33%"></div>
                                </div>

                                <!-- Registration Form -->
                                <form asp-action="Register" method="post" id="registrationForm">
                                    @Html.AntiForgeryToken()

                                    <!-- Step 1: Basic Info -->
                                    <div class="form-step active" id="step1">
                                        <h4 class="mb-4">Basic Information</h4>
                                        
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <div class="form-floating">
                                                    <input asp-for="FullName" class="form-control" placeholder="Full Name" required>
                                                    <label asp-for="FullName"></label>
                                                    <span asp-validation-for="FullName" class="text-danger small"></span>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-floating">
                                                    <input asp-for="Email" type="email" class="form-control" placeholder="Email" required>
                                                    <label asp-for="Email"></label>
                                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                                </div>
                                            </div>
                                            <div class="col-12">
                                                <div class="form-floating">
                                                    <input asp-for="PhoneNumber" class="form-control" placeholder="Phone Number">
                                                    <label asp-for="PhoneNumber"></label>
                                                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="d-flex justify-content-between mt-4">
                                            <div></div> <!-- Empty div for spacing -->
                                            <button type="button" class="btn btn-register" onclick="nextStep(2)">
                                                Next <i class="fas fa-arrow-right ms-2"></i>
                                            </button>
                                        </div>
                                    </div>

                                    <!-- Step 2: Password -->
                                    <div class="form-step" id="step2">
                                        <h4 class="mb-4">Set Password</h4>
                                        
                                        <div class="mb-3">
                                            <div class="form-floating">
                                                <input asp-for="Password" type="password" class="form-control" 
                                                       placeholder="Password" id="passwordInput" required>
                                                <label asp-for="Password"></label>
                                            </div>
                                            <div class="password-strength" id="passwordStrength"></div>
                                            <span asp-validation-for="Password" class="text-danger small"></span>
                                        </div>

                                        <div class="mb-4">
                                            <div class="form-floating">
                                                <input asp-for="ConfirmPassword" type="password" class="form-control" 
                                                       placeholder="Confirm Password" id="confirmPasswordInput" required>
                                                <label asp-for="ConfirmPassword"></label>
                                            </div>
                                            <div class="password-match" id="passwordMatch"></div>
                                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                                        </div>

                                        <div class="d-flex justify-content-between mt-4">
                                            <button type="button" class="btn btn-outline-secondary" onclick="prevStep(1)">
                                                <i class="fas fa-arrow-left me-2"></i> Back
                                            </button>
                                            <button type="button" class="btn btn-register" onclick="nextStep(3)">
                                                Next <i class="fas fa-arrow-right ms-2"></i>
                                            </button>
                                        </div>
                                    </div>

                                    <!-- Step 3: Address & Submit -->
                                    <div class="form-step" id="step3">
                                        <h4 class="mb-4">Shipping Address (Optional)</h4>
                                        
                                        <div class="row g-3">
                                            <div class="col-12">
                                                <div class="form-floating">
                                                    <input asp-for="Address" class="form-control" placeholder="Address">
                                                    <label asp-for="Address"></label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-floating">
                                                    <input asp-for="City" class="form-control" placeholder="City">
                                                    <label asp-for="City"></label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-floating">
                                                    <input asp-for="State" class="form-control" placeholder="State">
                                                    <label asp-for="State"></label>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-floating">
                                                    <input asp-for="ZipCode" class="form-control" placeholder="Zip Code">
                                                    <label asp-for="ZipCode"></label>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="form-check mt-4 mb-4">
                                            <input class="form-check-input" type="checkbox" id="terms" required>
                                            <label class="form-check-label" for="terms">
                                                I agree to the <a href="#" class="text-decoration-none">Terms of Service</a> and <a href="#" class="text-decoration-none">Privacy Policy</a>
                                            </label>
                                        </div>

                                        <div class="d-flex justify-content-between mt-4">
                                            <button type="button" class="btn btn-outline-secondary" onclick="prevStep(2)">
                                                <i class="fas fa-arrow-left me-2"></i> Back
                                            </button>
                                            <button type="submit" class="btn btn-register">
                                                <i class="fas fa-user-plus me-2"></i> Create Account
                                            </button>
                                        </div>
                                    </div>
                                </form>

                                <!-- Already have account -->
                                <div class="text-center mt-4">
                                    <p class="mb-0">Already have an account?
                                        <a asp-action="Login" class="text-decoration-none fw-bold">
                                            Sign in here
                                        </a>
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    
    <script>
        let currentStep = 1;

        function nextStep(step) {
            if (validateStep(currentStep)) {
                $('.form-step').removeClass('active');
                $('#step' + step).addClass('active');
                $('#registrationProgress').css('width', (step * 33) + '%');
                currentStep = step;
            }
        }

        function prevStep(step) {
            $('.form-step').removeClass('active');
            $('#step' + step).addClass('active');
            $('#registrationProgress').css('width', (step * 33) + '%');
            currentStep = step;
        }

        function validateStep(step) {
            let isValid = true;
            
            if (step === 1) {
                // Validate Step 1
                if (!$('#FullName').val().trim()) {
                    $('#FullName').addClass('is-invalid');
                    isValid = false;
                }
                if (!$('#Email').val().trim() || !isValidEmail($('#Email').val())) {
                    $('#Email').addClass('is-invalid');
                    isValid = false;
                }
            } else if (step === 2) {
                // Validate Step 2
                var password = $('#passwordInput').val();
                if (!password || password.length < 6) {
                    $('#passwordInput').addClass('is-invalid');
                    isValid = false;
                }
                if ($('#confirmPasswordInput').val() !== password) {
                    $('#confirmPasswordInput').addClass('is-invalid');
                    isValid = false;
                }
            }
            
            if (!isValid) {
                $('html, body').animate({
                    scrollTop: $('.form-step.active').offset().top - 100
                }, 500);
            }
            
            return isValid;
        }

        // Password strength checker
        $('#passwordInput').on('input', function() {
            var password = $(this).val();
            var strength = checkPasswordStrength(password);
            $('#passwordStrength').html(strength.html).attr('class', 'password-strength ' + strength.class);
        });

        // Password match checker
        $('#confirmPasswordInput').on('input', function() {
            var password = $('#passwordInput').val();
            var confirm = $(this).val();
            
            if (confirm && password !== confirm) {
                $('#passwordMatch').html('<span class="text-danger"><i class="fas fa-times-circle"></i> Passwords do not match</span>');
                $(this).addClass('is-invalid');
            } else if (confirm && password === confirm) {
                $('#passwordMatch').html('<span class="text-success"><i class="fas fa-check-circle"></i> Passwords match</span>');
                $(this).removeClass('is-invalid');
            } else {
                $('#passwordMatch').html('');
            }
        });

        function checkPasswordStrength(password) {
            var strength = 0;
            var tips = "";
            
            if (password.length >= 8) strength++;
            if (password.match(/[a-z]/) && password.match(/[A-Z]/)) strength++;
            if (password.match(/\d/)) strength++;
            if (password.match(/[^a-zA-Z\d]/)) strength++;
            
            if (strength < 2) {
                return { html: "Weak - Try adding more characters", class: "strength-weak" };
            } else if (strength === 2) {
                return { html: "Medium - Could be stronger", class: "strength-medium" };
            } else if (strength === 3) {
                return { html: "Good - Almost there", class: "strength-medium" };
            } else {
                return { html: "Strong - Great password!", class: "strength-strong" };
            }
        }

        function isValidEmail(email) {
            var re = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
            return re.test(email);
        }

        // Form submission
        $('#registrationForm').submit(function(e) {
            if (!$('#terms').is(':checked')) {
                e.preventDefault();
                alert('You must agree to the Terms of Service to create an account.');
                return false;
            }
            
            // Validate all steps
            for (let i = 1; i <= 3; i++) {
                if (!validateStep(i)) {
                    e.preventDefault();
                    nextStep(i); // Go to the step with errors
                    return false;
                }
            }
        });

        // Auto-focus
        $(document).ready(function() {
            $('#FullName').focus();
        });
    </script>
</body>
</html>
